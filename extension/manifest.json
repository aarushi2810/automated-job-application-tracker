{
  "manifest_version": 3,
  "name": "Job Application Auto Tracker",
  "version": "1.1",
  "description": "Automatically (and manually) save job applications from major job portals to your tracker backend.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://automated-job-application-tracker.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Job Application Tracker",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "*://*.greenhouse.io/*",
        "*://*.lever.co/*",
        "*://*.workday.com/*",
        "*://*.smartrecruiters.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
